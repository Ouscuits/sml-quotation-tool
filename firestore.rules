rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: get the logged-in user's profile
    function userData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function isAdmin() {
      return request.auth != null && userData().role == 'admin';
    }
    function isLoggedIn() {
      return request.auth != null;
    }
    function isOwnCountry(countryName) {
      let u = userData();
      return u.role == 'admin' || u.country == '' || u.country == countryName;
    }
    function isCountryUser(countryId) {
      let u = userData();
      let country = get(/databases/$(database)/documents/countries/$(countryId)).data;
      return u.role == 'admin' || u.country == '' || u.country == country.name;
    }

    // USERS: admin reads all, others read only themselves
    match /users/{userId} {
      allow read: if isLoggedIn() && (isAdmin() || request.auth.uid == userId);
      allow create, update, delete: if isAdmin();
    }

    // COUNTRIES: admin writes, authenticated users read their own
    match /countries/{countryId} {
      allow read: if isLoggedIn() && isCountryUser(countryId);
      allow create, update, delete: if isAdmin();

      // MACHINES: admin + own-country supervisor can write
      match /machines/{machineId} {
        allow read: if isLoggedIn() && isCountryUser(countryId);
        allow write: if isLoggedIn() && (isAdmin() || (userData().role == 'supervisor' && isCountryUser(countryId)));
      }

      // MATERIALS: admin + own-country supervisor can write
      match /materials/{materialId} {
        allow read: if isLoggedIn() && isCountryUser(countryId);
        allow write: if isLoggedIn() && (isAdmin() || (userData().role == 'supervisor' && isCountryUser(countryId)));
      }
    }

    // MACHINE TEMPLATES: all authenticated read, admin writes
    match /machineTemplates/{templateId} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();
    }

    // QUOTATIONS: user reads own, admin reads all
    match /quotations/{quotationId} {
      allow read: if isLoggedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow create: if isLoggedIn();
      allow update, delete: if isLoggedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
    }
  }
}
